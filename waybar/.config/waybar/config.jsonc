{
  "layer": "top",
  "position": "top",
  // Déjalo en 0 para que mande el CSS (evita el warning de mínimos)
  "height": 0,
  // Menos aire entre módulos
  "spacing": 6,
  "modules-left": [
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "cpu",
    "memory",
    "network",
    "pulseaudio",
    "battery",
    "custom/chargerate",
    "tray"
  ],
  "hyprland/workspaces": {
    "format": "{id}",
    "sort-by-number": true,
    "on-click": "activate"
  },
  "hyprland/windows": {
    "format": "{}",
    "max-length": 40
  },
  "clock": {
    "format": "{:%a %d %b  %H:%M}"
  },
  "cpu": {
    "format": "  {usage}%"
  },
  "memory": {
    "format": "  {percentage}%"
  },
  "network": {
    "format-wifi": "  {signalStrength}%",
    "format-ethernet": "󰈀  {ifname}",
    "format-disconnected": "󰖪  offline"
  },
  "pulseaudio": {
    "format": "  {volume}%",
    "format-muted": "󰝟  muted",
    "scroll-step": 5
  },
  "battery": {
    "format": "󰁹  {capacity}%",
    "format-charging": "󰂄  {capacity}%",
    "format-full": "󰁹  {capacity}%"
  },
  "tray": {
    // Más pequeño => baja el mínimo real del módulo
    "icon-size": 12,
    "spacing": 3
  },
  "custom/chargerate": {
    "exec": "upower -i $(upower -e | grep BAT) | rg energy-rate | rg -o '[0-9,]+ W'",
    "interval": 5,
    "format": "⚡ {}",
    "tooltip": false
  }
}
